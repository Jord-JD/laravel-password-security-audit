{
  "name": "jord-jd/laravel-password-security-audit",
  "description": "Laravel Password Security Audit",
  "type": "library",
  "require": {
    "php": ">=7.1.3",
    "laravel/framework": "^5.6 || ^6.0 || ^7.0 || ^8.0 || ^9.0 || ^10.0 || ^11.0 || ^12.0 || ^13.0",
    "jord-jd/php-cli-progress-bar": "^4.0",
    "jord-jd/php-password-cracker": "^3.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^7.5 || ^8.5 || ^9.6 || ^12.0"
  },
  "license": "LGPL-3.0-only",
  "authors": [
    {
      "name": "Jordan Hall",
      "email": "jordan@hall05.co.uk"
    }
  ],
  "autoload": {
    "psr-4": {
      "JordJD\\LaravelPasswordSecurityAudit\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "JordJD\\LaravelPasswordSecurityAudit\\ServiceProvider"
      ]
    },
    "branch-alias": {
      "dev-master": "3.1-dev"
    }
  },
  "replace": {
    "divineomega/laravel-password-security-audit": "self.version"
  }
}
